// Swaps without Borders — points ledger
// Day 4 schema. Connected to a live Supabase database from Day 5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL is used by `prisma migrate` to talk to the DB directly
  // (bypassing Supabase's pgbouncer connection pooler). DATABASE_URL
  // stays on the pooled connection for the running app.
  directUrl = env("DIRECT_URL")
}

/// One row per real on-chain swap executed through the dapp.
/// Source of truth for the leaderboard, the running tally, and the
/// points-weighted vote ballots.
model SwapEvent {
  id            String   @id @default(cuid())

  // Identity
  wallet        String   // checksummed src address — the points subject
  presetId      String?  // which SWAP_PRESETS entry was used, for analytics

  // Route
  srcChain      String   // ChainKeys value, e.g. "0xa4b1.arbitrum"
  dstChain      String   // ChainKeys value, e.g. "sonic"
  srcToken      String   // ERC-20 address on src chain
  dstToken      String   // ERC-20 address on dst chain
  srcSymbol     String
  dstSymbol     String

  // Amounts — bigints stored as decimal strings to avoid JS number loss
  srcAmountRaw  String   // e.g. "1500000" for 1.5 USDC (6 decimals)
  srcDecimals   Int
  dstQuotedRaw  String?
  dstDecimals   Int

  // USD-equivalent at submit time (pricing snapshot)
  usdValue      Decimal? @db.Decimal(20, 6)
  priceSource   String?  // "coingecko" | "cached" | "manual" — for audit

  // Points awarded (points-to-USD ratio is community-decided, Day 4 vote)
  pointsAwarded Int      @default(0)

  // Result — candidate hashes the confirm step verifies against the solver.
  // `getStatus` keys off the hub-chain (Sonic) tx; depending on the route
  // that surfaces as the destination tx (hub-dest swaps) or must be resolved
  // from the source tx, so we keep all three and let the server try each.
  txHash        String?  @unique  // source-spoke tx hash (intent creation)
  dstTxHash     String?  @unique  // destination tx hash (== hub tx for Sonic-dest)
  intentHash    String?  @unique  // solver intent_hash
  status        SwapStatus @default(submitted)

  createdAt     DateTime @default(now())
  confirmedAt   DateTime?

  @@index([wallet])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("swap_events")
}

enum SwapStatus {
  submitted
  confirmed
  failed
}

/// Curated shortlist seeded Day 8 from the community suggestion pool.
model Charity {
  id           String   @id @default(cuid())

  name         String
  blurb        String   // 1-2 sentence summary
  website      String?
  payoutKind   PayoutKind @default(wallet)
  payoutTarget String   // wallet address OR off-ramp identifier
  active       Boolean  @default(true)

  createdAt    DateTime @default(now())

  @@map("charities")
}

enum PayoutKind {
  wallet
  offramp
}

/// Threshold-based payout vote (Day 11 spec — admin opens a round with
/// 3 candidate charities; people vote via connected wallet, weighted by
/// their points balance at vote-cast time. 1 ballot per wallet per round.
/// Winner gets the full balance, cycle restarts.)
model VoteRound {
  id            String   @id @default(cuid())
  thresholdUsd  Decimal  @db.Decimal(20, 6)
  candidateIds  String[] // 3 charity cuid() refs (kept as denormalized array for simplicity)
  status        String   @default("open") // open | closed
  openedBy      String   // admin wallet that opened the round
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  closedBy      String?
  winnerId      String?
  ballots       VoteBallot[]

  @@index([status, openedAt])
  @@map("vote_rounds")
}

/// Single-use nonce ledger for signed admin actions (open/close round).
/// Each signed message embeds a random nonce; we record it on first use so
/// a captured signature can't be replayed. Unique PK = the replay guard.
model UsedNonce {
  nonce     String   @id
  action    String   // "OPEN_ROUND" | "CLOSE_ROUND"
  usedBy    String   // admin wallet that signed it
  createdAt DateTime @default(now())

  @@map("used_nonces")
}

/// One wallet's vote in a round. Points snapshot is captured at cast time
/// from the leaderboard (sum of pointsAwarded across that wallet's swaps).
model VoteBallot {
  id             String   @id @default(cuid())
  roundId        String
  round          VoteRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  wallet         String   // lowercased EVM address
  candidateId    String
  pointsSnapshot Int      @default(0)
  castAt         DateTime @default(now())

  @@unique([roundId, wallet])
  @@index([roundId, candidateId])
  @@map("vote_ballots")
}
