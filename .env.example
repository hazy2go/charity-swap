# CHARITY_WALLET_ADDRESS=
# PARTNER_FEE_BPS=30

# --- Database (Day 4+) ---------------------------------------------------
# DATABASE_URL=
# DIRECT_URL=

# --- Pricing (Day 4+) ----------------------------------------------------
# COINGECKO_API_KEY=

# --- Vote params (Day 11, community-decided) -----------------------------
# PAYOUT_THRESHOLD_USD=500
# VOTE_DURATION_HOURS=168
