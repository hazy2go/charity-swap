# --- RPCs (optional, public defaults are fine to start) -----------------
NEXT_PUBLIC_SONIC_RPC_URL=https://rpc.soniclabs.com
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# --- Wallet connect (needed for WalletConnect connector) ----------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

